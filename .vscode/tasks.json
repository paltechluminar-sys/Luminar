{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Dev Server (Web)",
      "type": "shell",
      "command": "npm",
      "args": ["start"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^(?:.*webpack.*|.*ready.*)",
          "endsPattern": "^(?:.*Compiled.*|.*webpack.*ready.*)"
        }
      }
    },
    {
      "label": "Deploy to Android (Mobile)",
      "type": "shell",
      "command": "npm",
      "args": ["run", "mobile:dev:run"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "dependsOn": ["Start Dev Server (Web)"]
    },
    {
      "label": "Run Both (Web + Mobile)",
      "type": "shell",
      "command": "echo",
      "args": ["Starting web and mobile..."],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent"
      },
      "dependsOn": [
        "Start Dev Server (Web)",
        "Deploy to Android (Mobile)"
      ],
      "problemMatcher": []
    }
  ]
}
